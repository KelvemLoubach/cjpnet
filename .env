# PostgreSQL connection string (Neon, Supabase, etc.)
# Formato: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Necessario para NextAuth.js - gere com: openssl rand -base64 32
NEXTAUTH_SECRET="cjp-net-cms-secret-key-2024"

# URL base do site (necessario para NextAuth.js em producao)
# NEXTAUTH_URL="https://SEU-SITE.netlify.app"
